void Sleep_Func(void)
{
static unsigned int Sleep_Time = 0;


if(B_OnOff_Flag || B_KEYHX_Flag || g_slave_charging || g_slave_chargefull || g_offshow_flag || kcomm_wakeup)
{
Sleep_Time = 0;
}
Sleep_Time++;
if(Sleep_Time >= 1000)
{
Sleep_Time = 0;
(PORTB1 = 1);
(PORTB0 = 1);
(PORTA7 = 1);
(PORTA6 = 1);
(PORTA4 = 1);

GIE = 0;
T0IE = 0;
T1IE = 0;
T2IE = 0;
INTECON = 0;
PIR = 0;

ADCON0 = 0;
ADCON1 = 0;
ANSELL = 0;
ANSELH = 0;


TRISA = 0x0E;
TRISB = 0x48;

PHCON1 = 0xF1;
PHCON = 0xFF;
PDCON1 = 0xFF;
PDCON = 0xBF;

delay_us(1000);

BOREN = 0;
WDTEN = 0;


IOCA = 0x0E;
IOCB = 0x40;

unsigned char temp;
temp = PORTA;
temp = PORTB;
(void)temp;

PAIF = 0;
PBIF = 0;
PAIE = 1;
PBIE = 1;


# 294
#asm
         clrwdt
         nop
         sleep
         nop
#endasm  	 
         WDTEN = 1;
ADEN = 1;


if(((PORTB & 0x40) ? 1 : 0))
{

g_slave_charging = 1;
g_slave_alive_ms = 3000;


while(((PORTB & 0x40) ? 1 : 0))
{

# 313
#asm
                    clrwdt
#endasm 
                    }


kcomm_cycle = 195;
kcomm_wakeup = 0;
}

temp = PORTA;
temp = PORTB;
(void)temp;
PAIF = 0;
PBIF = 0;
PAIE = 0;
PBIE = 0;

if(!PORTA2 || !PORTA1)
{
B_KEYHX_Flag = 1;
}
inital();
sysinitial();
ADC_Init();
BOREN = 1;
Sleep_Time = 0;
DIY_Flag1.OnrBit.b0 = 0;
}
}

# 348
void ADC_Init(void)
{
ANSELL=0X20;
ANSELH=0X00;
ADCON0=0X15;
adcon1_val = 0X08;
ADCON1 = adcon1_val;
ADEN = 1;
delay_us(100);
}

# 362
unsigned int adc_read_vdd(void)
{
unsigned int result;
unsigned int ad_delay;

ADCON0 = 0x15;
ADCON1 = adcon1_val;
ADEN = 1;

ADIF = 0;
ADON = 1;

ad_delay = 0;
while(ADON)
{

# 377
#asm
        clrwdt
#endasm 
        ad_delay++;
if(ad_delay >= 20000)
break;
}

result = ((unsigned int)ADRESH << 4) | (ADRESL >> 4);
return result;
}
void LedMode_Func(void)
{

static unsigned char chg_pwm_cnt = 0;
static unsigned char breath_duty = 0;
static unsigned char breath_dir = 1;
static unsigned char breath_cnt = 0;
static unsigned char disp_level = 0;
static unsigned char lv_debounce = 0;


if(g_battery_empty)
{
(PORTB1 = 1);
(PORTB0 = 1);
(PORTA7 = 1);
(PORTA6 = 1);
(PORTA4 = 1);
return;
}

if(disp_level != level)
{
if(lv_debounce < 3) lv_debounce++;
if(lv_debounce >= 3) disp_level = level;
}
else
{
lv_debounce = 0;
}

if((g_slave_charging || g_slave_chargefull) && !B_OnOff_Flag)
{

breath_cnt++;
if(breath_cnt >= 50)
{
breath_cnt = 0;
if(breath_dir)
{
if(breath_duty < 20) breath_duty++;
else breath_dir = 0;
}
else
{
if(breath_duty > 0) breath_duty--;
else breath_dir = 1;
}
}


chg_pwm_cnt++;
if(chg_pwm_cnt >= 20)
chg_pwm_cnt = 0;

if(g_slave_chargefull)
{

(PORTB1 = 0); (PORTB0 = 0); (PORTA7 = 0); (PORTA6 = 0); (PORTA4 = 0);
breath_duty = 20;
breath_dir = 0;
breath_cnt = 0;
}
else
{

# 458
if(disp_level >= 2) { (PORTA4 = 0); }
else if(disp_level == 1) { if(chg_pwm_cnt < breath_duty) (PORTA4 = 0); else (PORTA4 = 1); }
else { (PORTA4 = 1); }


if(disp_level >= 3) { (PORTA6 = 0); }
else if(disp_level == 2) { if(chg_pwm_cnt < breath_duty) (PORTA6 = 0); else (PORTA6 = 1); }
else { (PORTA6 = 1); }


if(disp_level >= 4) { (PORTA7 = 0); }
else if(disp_level == 3) { if(chg_pwm_cnt < breath_duty) (PORTA7 = 0); else (PORTA7 = 1); }
else { (PORTA7 = 1); }


if(disp_level >= 5) { (PORTB0 = 0); }
else if(disp_level == 4) { if(chg_pwm_cnt < breath_duty) (PORTB0 = 0); else (PORTB0 = 1); }
else { (PORTB0 = 1); }


if(disp_level >= 6) { (PORTB1 = 0); }
else if(disp_level == 5) { if(chg_pwm_cnt < breath_duty) (PORTB1 = 0); else (PORTB1 = 1); }
else { (PORTB1 = 1); }
}
return;
}


if(B_OnOff_Flag && g_gear == 6)
{
breath_cnt++;
if(breath_cnt >= 20)
{
breath_cnt = 0;
if(breath_dir)
{
if(breath_duty < 50) breath_duty++;
else breath_dir = 0;
}
else
{
if(breath_duty > 0) breath_duty--;
else breath_dir = 1;
}
g_overclock_pwm = breath_duty;
}
return;
}


if(!g_slave_charging && !g_slave_chargefull && g_gear != 6)
{
breath_duty = 0;
breath_dir = 1;
breath_cnt = 0;
chg_pwm_cnt = 0;
}


if(!B_OnOff_Flag && g_offshow_flag)
{
show_gear_led(level);
return;
}


if(B_OnOff_Flag && g_warn_flash > 0)
return;


if(B_OnOff_Flag)
{
show_gear_led(g_gear);
return;
}


(PORTB1 = 1);
(PORTB0 = 1);
(PORTA7 = 1);
(PORTA6 = 1);
(PORTA4 = 1);
}
void Battery_Update(void)
{
static unsigned char low_debounce = 0;
static unsigned char low_clr_debounce = 0;
unsigned int adc_val;
static unsigned char loop_num = 0;
static unsigned int loop_min = 0;
static unsigned int loop_max = 0;
static unsigned int loop_sum = 0;
static unsigned char startup_cnt = 50;
adc_val = adc_read_vdd();

if(loop_num == 0)
{
loop_min = adc_val;
loop_max = adc_val;
loop_sum = 0;
}
else if(loop_min > adc_val) loop_min = adc_val;
else if(loop_max < adc_val) loop_max = adc_val;

loop_sum += adc_val;
loop_num++;

if(loop_num >= 10)
{
loop_num = 0;
loop_sum -= loop_min;
loop_sum -= loop_max;
loop_sum = loop_sum >> 3;
g_vdd_adc = loop_sum;

if(g_slave_chargefull) level = 6;
else if(g_vdd_adc < 2363u) level = 0;
else if(g_vdd_adc < 2544u) level = 1;
else if(g_vdd_adc < 2914u) level = 2;
else if(g_vdd_adc < 3072u) level = 3;
else if(g_vdd_adc < 3229u) level = 4;
else if(g_vdd_adc <= 3308u) level = 5;
else level = 6;
if(startup_cnt > 0)
{
startup_cnt--;
B_LowPower_Flag = 0;
}
else
{
if(B_LowPower_Flag == 0)
{

if(g_vdd_adc < 2521u)
{
if(low_debounce < 5) low_debounce++;
if(low_debounce >= 5) B_LowPower_Flag = 1;
}
else
{
low_debounce = 0;
}
}
else
{
if(g_vdd_adc >= 2544u)
{
if(low_clr_debounce < 3) low_clr_debounce++;
if(low_clr_debounce >= 3)
{
B_LowPower_Flag = 0;
low_debounce = 0;
}
}
else
{
low_clr_debounce = 0;
}
}
}
}
}

# 626
void show_gear_led(unsigned char gear)
{
(PORTB1 = 1);
(PORTB0 = 1);
(PORTA7 = 1);
(PORTA6 = 1);
(PORTA4 = 1);
if(gear >= 1) (PORTA4 = 0);
if(gear >= 2) (PORTA6 = 0);
if(gear >= 3) (PORTA7 = 0);
if(gear >= 4) (PORTB0 = 0);
if(gear >= 5) (PORTB1 = 0);
}

# 645
void set_fan(unsigned char gear)
{
if(gear == 0)
{
g_target_pwm = 0;
return;
}
if(gear > 6)
gear = 6;

g_target_pwm = c_fan_duty[gear];
}

# 661
void fan_ramp_proc(void)
{
unsigned int target_fixed = (unsigned int)g_target_pwm << 4;

if(g_current_pwm < target_fixed)
{
g_current_pwm += 1;
if(g_current_pwm > target_fixed) g_current_pwm = target_fixed;
}
else if(g_current_pwm > target_fixed)
{
g_current_pwm -= 1;
if(g_current_pwm < target_fixed) g_current_pwm = target_fixed;
}

PWM0P = (unsigned char)(g_current_pwm >> 4);
if(PWM0P == 0) PORTB2 = 0;
}

# 687
void trigger_warn(unsigned char led_num)
{
if(g_warn_flash == 0)
{
g_warn_flash = 4;
g_warn_led = led_num;
g_warn_blink = 0;
g_warn_cnt = 0;
}
}

# 700
void warn_flash_proc(void)
{
if(g_warn_flash == 0)
return;
g_warn_cnt++;
if(g_warn_cnt < 150)
return;
g_warn_cnt = 0;


g_warn_blink = !g_warn_blink;
g_warn_flash--;

if(g_warn_led == 1)
{

(PORTA4 = 0); (PORTA6 = 0); (PORTA7 = 0); (PORTB0 = 0);
if(g_warn_blink) (PORTB1 = 1); else (PORTB1 = 0);
}
else if(g_warn_led == 5)
{

(PORTB1 = 1);
(PORTB0 = 1);
(PORTA7 = 1);
(PORTA6 = 1);
if(g_warn_blink) (PORTA4 = 1); else (PORTA4 = 0);
}


if(g_warn_flash == 0)
{
show_gear_led(g_gear);
}
}


void Key_Func(void)
{
static unsigned char key1_time1 = 0;
static unsigned char key1_time2 = 0;
static unsigned char key2_time1 = 0;
static unsigned char key2_time2 = 0;

if(!PORTA2)
{
key1_time2 = 0;
key1_time1 ++;
if(key1_time1 >= 10)
{
key1_time1 = 0;
DIY_Flag1.OnrBit.b1 = 1;
}
}
else
{

key1_time1 = 0;
key1_time2 ++;
if(key1_time2 >= 10)
{
key1_time2 = 0;
DIY_Flag1.OnrBit.b1 = 0;
}
}

if(!PORTA1)
{
key2_time2 = 0;
key2_time1 ++;
if(key2_time1 >= 10)
{
key2_time1 = 0;
DIY_Flag1.OnrBit.b2 = 1;
}
}
else
{

key2_time1 = 0;
key2_time2 ++;
if(key2_time2 >= 10)
{
key2_time2 = 0;
DIY_Flag1.OnrBit.b2 = 0;
}
}
}

void SW_Func()
{
static unsigned char sw_time1 = 0;
static unsigned char sw_time2 = 0;

if(PORTA3)
{

sw_time2 = 0;
sw_time1 ++;
if(sw_time1 >= 20)
{
sw_time1 = 0;
B_OnOff_Flag = 0;
B_KEYHX_Flag = 0;
}
}
else
{

sw_time1 = 0;
sw_time2 ++;
if(sw_time2 >= 20)
{
sw_time2 = 0;
B_OnOff_Flag = 1;
B_KEYHX_Flag = 0;
}
}
}

# 836
void Key_Application()
{
unsigned char edge;
unsigned char cur;
static unsigned char off_key_prev = 0;
warn_flash_proc();


if(g_vdd_adc <= 2363u)
{
g_battery_empty = 1;
}
else if(g_vdd_adc >= 2387u)
{
g_battery_empty = 0;
}

if(g_battery_empty)
{
B_OnOff_Flag = 0;
set_fan(0);
(PORTB1 = 1);
(PORTB0 = 1);
(PORTA7 = 1);
(PORTA6 = 1);
(PORTA4 = 1);
g_offshow_flag = 0;
g_offshow_ms = 0;
g_warn_flash = 0;
g_gear = 0;
g_k1_prev = DIY_Flag1.OnrBit.b1;
g_k2_prev = DIY_Flag1.OnrBit.b2;
g_k2_hold_ms = 0;
return;
}

# 875
if(B_OnOff_Flag == 0)
{
g_pwr_delay_ms = 0;
edge = 0;
if(B_KEYHX_Flag)
{
edge = 1;
B_KEYHX_Flag = 0;
}
cur = DIY_Flag1.OnrBit.b1 || DIY_Flag1.OnrBit.b2;
if(cur && !off_key_prev)
edge = 1;
off_key_prev = cur;
if(edge)
{
Battery_Update();
g_offshow_flag = 1;
g_offshow_ms = 0;
show_gear_led(level);
}
if(g_offshow_flag)
{
g_offshow_ms++;
if(g_offshow_ms >= 5000)
{
g_offshow_flag = 0;
g_offshow_ms = 0;
(PORTB1 = 1);
(PORTB0 = 1);
(PORTA7 = 1);
(PORTA6 = 1);
(PORTA4 = 1);
}
}

if(g_gear != 0)
{
g_gear = 0;
set_fan(0);
(PORTB1 = 1);
(PORTB0 = 1);
(PORTA7 = 1);
(PORTA6 = 1);
(PORTA4 = 1);
g_warn_flash = 0;
}
g_k1_prev = DIY_Flag1.OnrBit.b1;
g_k2_prev = DIY_Flag1.OnrBit.b2;
g_k2_hold_ms = 0;
return;
}

# 931
if(g_pwr_delay_ms < 1000)
{
g_pwr_delay_ms++;
(PORTB1 = 1);
(PORTB0 = 1);
(PORTA7 = 1);
(PORTA6 = 1);
(PORTA4 = 1);
g_k1_prev = DIY_Flag1.OnrBit.b1;
g_k2_prev = DIY_Flag1.OnrBit.b2;
g_k2_hold_ms = 0;
return;
}


if(g_slave_charging || g_slave_chargefull)
{
g_gear = 1;
set_fan(1);
g_offshow_flag = 0;

if(g_warn_flash == 0)
show_gear_led(1);


if(DIY_Flag1.OnrBit.b2 && !g_k2_prev) trigger_warn(5);
if(DIY_Flag1.OnrBit.b1 && !g_k1_prev) trigger_warn(5);

g_k1_prev = DIY_Flag1.OnrBit.b1;
g_k2_prev = DIY_Flag1.OnrBit.b2;
g_k2_hold_ms = 0;
return;
}
else
{

if(g_gear == 0)
{
g_gear = 1;
set_fan(1);
show_gear_led(1);
}

if(g_warn_flash > 0)
{
g_k1_prev = DIY_Flag1.OnrBit.b1;
g_k2_prev = DIY_Flag1.OnrBit.b2;
g_k1_hold_ms = 0;
g_k2_hold_ms = 0;
return;
}


if(DIY_Flag1.OnrBit.b2)
{
g_k2_hold_ms++;

if(g_k2_hold_ms == 500 || g_k2_hold_ms == 600 || g_k2_hold_ms == 700 || g_k2_hold_ms == 800 || g_k2_hold_ms == 900)
{
if(g_gear < 5)
{
g_gear++;
set_fan(g_gear);
show_gear_led(g_gear);
}
else if(g_gear == 5)
{
g_gear = 6;
set_fan(6);
}
}
}
else
{

if(g_k2_prev)
{
if(g_gear == 6)
{

g_gear = 5;
set_fan(5);
show_gear_led(5);
}
else if(g_k2_hold_ms < 500)
{

if(g_gear < 5)
{
g_gear++;
set_fan(g_gear);
show_gear_led(g_gear);
}
else if(g_gear == 5)
{
trigger_warn(1);
}
}
}
g_k2_hold_ms = 0;
}
g_k2_prev = DIY_Flag1.OnrBit.b2;


if(DIY_Flag1.OnrBit.b1)
{
g_k1_hold_ms++;

if(g_k1_hold_ms == 500 || g_k1_hold_ms == 600 || g_k1_hold_ms == 700 || g_k1_hold_ms == 800 || g_k1_hold_ms == 900)
{
if(g_gear > 1)
{
g_gear--;
set_fan(g_gear);
show_gear_led(g_gear);
}
}
}
else
{

if(g_k1_prev)
{
if(g_k1_hold_ms < 500)
{

if(g_gear > 1)
{
g_gear--;
set_fan(g_gear);
show_gear_led(g_gear);
}
else if(g_gear == 1)
{
trigger_warn(5);
}
}
}
g_k1_hold_ms = 0;
}
g_k1_prev = DIY_Flag1.OnrBit.b1;
}
}

# 1080
static unsigned char comm_pack_tx(void)
{
unsigned char lo = 0;
unsigned char hi;
unsigned char result;


if(!PORTA3)
{
lo |= 0x01;
}

if(B_OnOff_Flag)
{
lo |= 0x04;


if(B_LowPower_Flag)
lo |= 0x02;
}


lo = lo & 0x0F;
hi = lo ^ 0x0F;
result = (hi << 4) | lo;
return result;
}

# 1112
static unsigned char comm_parse_rx(unsigned char raw)
{
unsigned char lo;
unsigned char hi;
unsigned char check;

lo = raw & 0x0F;
hi = (raw >> 4) & 0x0F;
check = lo + hi;

if(check != 0x0F)
return 0;

if(lo == 0x0C || lo == 0x0D)
g_slave_charging = 1;
else
g_slave_charging = 0;

if(lo == 0x0D)
g_slave_chargefull = 1;
else
g_slave_chargefull = 0;

return 1;
}

# 1140
void Kcomm_ISR(void)
{
static unsigned char bit_wait_fall;
kcomm_timer++;

if(kcomm_wakeup)
{
kcomm_wakeup_cnt++;
if(kcomm_wakeup_cnt == 1)
{
do { TRISB6 = 0; } while(0);
PORTB6 = 1;
}
if(kcomm_wakeup_cnt >= 1000u)
{
PORTB6 = 0;
do { TRISB6 = 1; } while(0);
kcomm_wakeup = 0;
kcomm_wakeup_cnt = 0;
kcomm_low_cnt = 0;
kcomm_state = 0;
kcomm_cycle = 195;
}
return;
}


if(kcomm_state == 0)
{
kcomm_cycle++;

if(!((PORTB & 0x40) ? 1 : 0))
{
if(kcomm_low_cnt < 1000)
kcomm_low_cnt++;


if(kcomm_low_cnt >= 1000)
{
kcomm_low_cnt = 1000;

if(kcomm_wakeup == 0)
{
if(B_OnOff_Flag || g_slave_charging || g_slave_chargefull)
{
kcomm_wakeup = 1;
kcomm_wakeup_cnt = 0;
}
}
}
}
else
{
kcomm_low_cnt = 0;
}


if(kcomm_cycle >= 200)
{
kcomm_cycle = 0;

if(kcomm_turn == 0)
{

kcomm_tx_buf = comm_pack_tx();
kcomm_bit_idx = 0;
kcomm_timer = 0;
kcomm_tx_done = 0;
do { TRISB6 = 0; } while(0);
PORTB6 = 1;
kcomm_state = 1;
}
else
{

kcomm_rx_buf = 0;
kcomm_bit_idx = 0;
kcomm_timer = 0;
kcomm_rx_done = 0;
do { TRISB6 = 0; } while(0);
PORTB6 = 1;
kcomm_state = 5;
}
}
return;
}
switch(kcomm_state)
{

case 1:
if(kcomm_timer >= 20)
{
kcomm_timer = 0;
PORTB6 = 0;
kcomm_state = 2;
}
else
{
PORTB6 = 1;
}
break;

case 2:
if(kcomm_timer >= 10)
{
kcomm_timer = 0;
kcomm_tx_shift = kcomm_tx_buf;
kcomm_bit_idx = 0;
PORTB6 = 1;
kcomm_state = 3;
}
break;

case 3:


if(kcomm_timer >= 14)
{

kcomm_timer = 0;
kcomm_bit_idx ++;
if(kcomm_bit_idx >= 8)
{
PORTB6 = 0;
kcomm_state = 4;

kcomm_cycle= 0;
}
else
{
kcomm_tx_shift <<= 1;
}
}
else
{
if(kcomm_tx_shift & 0x80)
{
if(kcomm_timer <= 10)
{
PORTB6 = 1;
}
else
{
PORTB6 = 0;
}
}
else
{
if(kcomm_timer <= 4)
{
PORTB6 = 1;
}
else
{
PORTB6 = 0;
}
}
}
break;
case 4:
if(kcomm_timer >= 20)
{
PORTB6 = 0;
do { TRISB6 = 1; } while(0);
kcomm_tx_done = 1;
kcomm_turn = 1;
kcomm_timer = 0;
kcomm_state = 0;
}
break;

case 5:
if(kcomm_timer >= 40)
{
kcomm_timer = 0;
PORTB6 = 0;
kcomm_state = 6;
}
else
{
PORTB6 = 1;
}
break;

case 6:
if(kcomm_timer >= 10)
{
kcomm_timer = 0;
bit_wait_fall = 0;
kcomm_bit_idx = 0;
kcomm_rx_shift = 0;
do { TRISB6 = 1; } while(0);
PORTB6 = 0;
kcomm_state = 9;
}
break;

case 9:
if(kcomm_timer >= ((kcomm_bit_idx == 0 && bit_wait_fall == 0) ? 400u : 60u))
{
kcomm_rx_done = 0xFF;
kcomm_turn = 0;
kcomm_timer = 0;
kcomm_state = 0;
break;
}
if(bit_wait_fall == 0)
{

if(((PORTB & 0x40) ? 1 : 0))
{
kcomm_timer = 0;
bit_wait_fall = 1;
}
}
else
{

if(!((PORTB & 0x40) ? 1 : 0))
{
kcomm_rx_shift <<= 1;
if(kcomm_timer >= 7)
kcomm_rx_shift |= 1;

bit_wait_fall = 0;
kcomm_bit_idx++;

if(kcomm_bit_idx >= 8)
{
kcomm_rx_buf = kcomm_rx_shift;
kcomm_rx_done = 1;
kcomm_turn = 0;
kcomm_timer = 0;
kcomm_state = 10;
}
}
}
break;
case 10:
if(kcomm_timer >= 10)
{
kcomm_timer = 0;
kcomm_state = 0;
}
break;
default:
kcomm_state = 0;
break;
}
}
void Comm_Process(void)
{
unsigned char rx_ok;

if(kcomm_tx_done == 1)
{
kcomm_tx_done = 0;
}

if(kcomm_rx_done == 1)
{
kcomm_rx_done = 0;
rx_ok = comm_parse_rx(kcomm_rx_buf);
if(rx_ok)
g_slave_alive_ms = 200;
if(g_slave_charging || g_slave_chargefull)
g_slave_alive_ms = 200;
}
else if(kcomm_rx_done == 0xFF)
{
kcomm_rx_done = 0;
}
}

void Flag_AllClear(void)
{
(PORTB1 = 1);
(PORTB0 = 1);
(PORTA7 = 1);
(PORTA6 = 1);
(PORTA4 = 1);
B_OnOff_Flag = 0;
B_LowPower_Flag = 0;
g_gear = 0;
g_warn_flash = 0;
g_warn_cnt = 0;
g_warn_led = 0;
g_warn_blink = 0;
g_offshow_flag = 0;
g_offshow_ms = 0;
g_slave_charging = 0;
g_slave_chargefull = 0;
g_slave_alive_ms = 0;
g_k1_prev = 0;
g_k2_prev = 0;
g_k2_hold_ms = 0;
B_KEYHX_Flag = 0;
kcomm_state = 0;
kcomm_turn = 0;
kcomm_timer = 0;
kcomm_cycle = 0;
kcomm_wakeup = 0;
kcomm_wakeup_cnt= 0;
kcomm_low_cnt = 0;
kcomm_rx_done = 0;
kcomm_tx_done = 0;
level = 0;
g_vdd_adc = 3308u;
}




void main(void)
{
ramInitial();
inital();
Delay_Init(200);
ADC_Init();
T1_PWM_inital();
sysinitial();
WDTEN = 1;

Flag_AllClear();
set_fan(0);
while(1)
{
T0IE = 1;
GIE = 1;
if(DIY_Flag1.OnrBit.b0)
{
DIY_Flag1.OnrBit.b0 = 0;

# 1472
#asm
   clrwdt
#endasm ;


   Comm_Process();
if(g_slave_alive_ms > 0)
{
g_slave_alive_ms--;
}
else
{
if(g_slave_charging || g_slave_chargefull)
{

g_gear = 0;
g_warn_flash = 0;
}

g_slave_charging = 0;
g_slave_chargefull = 0;
}

Battery_Update();
Key_Func();
SW_Func();
Key_Application();
fan_ramp_proc();
LedMode_Func();
Sleep_Func();
}
}
}


void interrupt Timer1_Isr(void)
{
static unsigned char timer_ms = 0;
static unsigned char pwm_cnt = 0;

if(T0IF == 1)
{
T0IF = 0;
T0 = 168;
timer_ms++;

if(timer_ms >= 20)
{
timer_ms = 0;
DIY_Flag1.OnrBit.b0 = 1;
}
}

if(B_OnOff_Flag && g_gear == 6 && !g_slave_charging && !g_slave_chargefull)
{
pwm_cnt++;
if(pwm_cnt >= 50) pwm_cnt = 0;

if(pwm_cnt < g_overclock_pwm)
{
(PORTB1 = 0); (PORTB0 = 0); (PORTA7 = 0); (PORTA6 = 0); (PORTA4 = 0);
}
else
{
(PORTB1 = 1); (PORTB0 = 1); (PORTA7 = 1); (PORTA6 = 1); (PORTA4 = 1);
}
}

Kcomm_ISR();
T1IF = 0;
}

