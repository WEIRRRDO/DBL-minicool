#define KEDA_SET_OUTPUT()   do { KEDA_TRIS = 0; } while(0)
#define KEDA_SET_INPUT()    do { KEDA_TRIS = 1; } while(0)

#define KEDA_READ()   		((PORTB & 0x40) ? 1 : 0)
/*----------------------------------------------------------------------
 *  ��������֡�ṹ��8bit��  D3D2D1D0-C3C2C1C0
 *  ��4λ D[3:0] = ~C[3:0]����Ϊ����У�飩
 *
 *  C3 = 0��δ�ã�
 *  C2 = 1 �п��� / 0 û�п���
 *  C1 = 1 ������ / 0 ��������
 *  C0 = 1 ��Ҫ������幩�� / 0 ����Ҫ
 *----------------------------------------------------------------------*/
typedef union {
    unsigned char byte;
    struct {
        unsigned C0 : 1;   /* bit0 */
        unsigned C1 : 1;   /* bit1 */
        unsigned C2 : 1;   /* bit2 */
        unsigned C3 : 1;   /* bit3���̶�0 */
        unsigned D0 : 1;   /* bit4 = ~C0 */
        unsigned D1 : 1;   /* bit5 = ~C1 */
        unsigned D2 : 1;   /* bit6 = ~C2 */
        unsigned D3 : 1;   /* bit7 = ~C3 */
    } bits;
} CommTxFrame;
/*----------------------------------------------------------------------
 *  �ӻ��ش�֡�ṹ��8bit��  B3B2B1B0-A3A2A1A0
 *  ��4λ B[3:0] = ~A[3:0]����Ϊ����У�飩
 *
 *  A3A2 = 11 ���ڳ���� / 00 δ���
 *  A1A0 = 01 �ѳ���    / 00 δ����
 *----------------------------------------------------------------------*/
typedef union {
    unsigned char byte;
    struct {
        unsigned A0 : 1;
        unsigned A1 : 1;
        unsigned A2 : 1;
        unsigned A3 : 1;
        unsigned B0 : 1;
        unsigned B1 : 1;
        unsigned B2 : 1;
        unsigned B3 : 1;
    } bits;
} CommRxFrame;
typedef enum {
    COMM_IDLE = 0,      /* ���У��������룩*/
    COMM_TX_CMD,        /* ���ڷ�������֡ */
    COMM_RX_CMD,        /* ���ڽ��մӻ�֡ */
    COMM_SLEEP_DETECT,  /* ���Է��Ƿ����͹��� */
    COMM_WAKEUP,        /* ���ѶԷ������50ms�ߵ�ƽ��*/
} CommState;
