unsigned char kcomm_rx_buf;    // ���ջ���
unsigned char kcomm_bit_idx;    // bit���� 0~7
unsigned char kcomm_turn;    // 0=������ 1=������
u8  kcomm_cycle;    // 10ms���ڼ�ʱ�����ж��������
unsigned char kcomm_rx_done;    // 1=�յ�һ֡������ѭ������
unsigned char kcomm_rx_shift;	// ����ʱ���ѽ���bit����0~8��������λ�ƺ��жϽ������
unsigned char kcomm_tx_done;    // 1=������һ֡
